---
import { fetchEntries } from '../../lib/notion';

export async function getStaticPaths() {
  const entries = await fetchEntries();
  const pohadky = entries.filter(e => e.type === 'Říkadlo');
  
  return pohadky.map(p => ({
    params: { slug: p.slug },
    props: { p }
  }));
}

const { p } = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{p.title} | Noční knihovna</title>
  <meta name="description" content={`Poslechněte si čtenou pohádku ${p.title} v Noční knihovně. Uklidňující hlas a jemný ASMR podkres.`}>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
   .serif { font-family: 'Lora', serif; }
  </style>
</head>
<body class="bg-[#090a10] text-[#e2e8f0] min-h-screen flex flex-col justify-between">

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#1e1b4b]/30 via-[#090a10] to-[#090a10] -z-10"></div>

  <main class="max-w-2xl mx-auto px-4 py-16 w-full space-y-8">
    
    <nav class="text-sm">
      <a href="/" class="text-[#c084fc] hover:underline">← Zpět do knihovny</a>
    </nav>

    <header class="space-y-4">
      <span class="text-xs font-bold uppercase tracking-wider text-[#c084fc]">Čtená pohádka</span>
      <h1 class="serif text-4xl font-semibold text-white">{p.title}</h1>
      
      <div class="flex flex-wrap gap-2 pt-2">
        {p.youtube && (
          <a href={p.youtube} target="_blank" class="px-4 py-2 bg-[#ef4444]/20 text-[#fca5a5] text-xs font-semibold rounded-xl hover:bg-[#ef4444]/30">Přehrát na YouTube 📺</a>
        )}
        {p.spotify && (
          <a href={p.spotify} target="_blank" class="px-4 py-2 bg-[#22c55e]/20 text-[#a7f3d0] text-xs font-semibold rounded-xl hover:bg-[#22c55e]/30">Poslouchat na Spotify 🟢</a>
        )}
        {p.herohero && (
          <a href={p.herohero} target="_blank" class="px-4 py-2 bg-[#c084fc]/20 text-[#e9d5ff] text-xs font-semibold rounded-xl hover:bg-[#c084fc]/30">Bez reklam na Herohero ✨</a>
        )}
      </div>
    </header>

    <article class="prose prose-invert max-w-none text-sm text-[#cbd5e1] leading-relaxed whitespace-pre-line bg-[#131520] p-8 rounded-3xl border border-[#c084fc]/5">
      {p.content}
    </article>

    <footer class="space-y-4 pt-6 border-t border-[#c084fc]/10">
      <h3 class="serif text-lg font-medium text-white">Doporučujeme k pohádce:</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {p.alza && (
          <a href={p.alza} target="_blank" class="p-4 bg-[#1b1e2e] hover:bg-[#252a3f] border border-[#c084fc]/5 rounded-2xl block">
            <span class="text-[10px] font-bold text-[#c084fc] uppercase">Affiliate tip</span>
            <h4 class="font-medium text-white mt-1">Papírová knížka na Alze</h4>
            <p class="text-xs text-[#64748b] mt-0.5">Listujte si společně u poslechu</p>
          </a>
        )}
        {p.etsy && (
          <a href={p.etsy} target="_blank" class="p-4 bg-[#1b1e2e] hover:bg-[#252a3f] border border-[#c084fc]/5 rounded-2xl block">
            <span class="text-[10px] font-bold text-[#f97316] uppercase">Z našeho e-shopu</span>
            <h4 class="font-medium text-white mt-1">Plakát & Omalovánka</h4>
            <p class="text-xs text-[#64748b] mt-0.5">Nádherná perokresba zvířátka</p>
          </a>
        )}
      </div>
    </footer>

  </main>

  <footer class="w-full text-center py-8 text-xs text-[#475569] border-t border-[#c084fc]/5 mt-16 bg-[#06070a]/50">
    <p>© 2026 Noční knihovna.</p>
  </footer>
</body>
</html>
