---
import { fetchEntries } from '../../lib/notion';

export async function getStaticPaths() {
  const entries = await fetchEntries() ||;
  const pisnicky = entries.filter(e => e.type === 'Písnička');
  
  if (pisnicky.length === 0) {
    return [{
      params: { slug: 'pripravujeme' },
      props: { s: { title: 'Písničky připravujeme', content: 'Již brzy zde najdete texty písniček.', isPlaceholder: true } }
    }];
  }
  
  return pisnicky.map(s => ({
    params: { slug: s.slug },
    props: { s }
  }));
}

const { s } = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{s.title} | Noční knihovna</title>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  .serif { font-family: 'Lora', serif; }
  </style>
</head>
<body class="bg-[#090a10] text-[#e2e8f0] min-h-screen flex flex-col justify-between">

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#1e1b4b]/30 via-[#090a10] to-[#090a10] -z-10"></div>

  <main class="max-w-2xl mx-auto px-4 py-16 w-full space-y-8">
    
    <nav class="text-sm">
      <a href="/" class="text-[#c084fc] hover:underline">← Zpět do knihovny</a>
    </nav>

    <header class="space-y-4">
      <span class="text-xs font-bold uppercase tracking-wider text-[#c084fc]">Lidová písnička</span>
      <h1 class="serif text-4xl font-semibold text-white">{s.title}</h1>
      
      {!s.isPlaceholder && s.herohero && (
        <div class="pt-2">
          <a href={s.herohero} target="_blank" class="inline-flex items-center px-5 py-3 bg-[#c084fc] text-[#090a10] hover:bg-[#d8b4fe] text-xs font-bold rounded-xl transition-all shadow-md">
            🎤 Přehrát zpívanou verzi na Herohero
          </a>
        </div>
      )}
    </header>

    <article class="serif text-center prose prose-invert max-w-none text-md text-[#cbd5e1] leading-relaxed whitespace-pre-line bg-[#131520] p-10 rounded-3xl border border-[#c084fc]/5">
      {s.content}
    </article>

  </main>

  <footer class="w-full text-center py-8 text-xs text-[#475569] border-t border-[#c084fc]/5 mt-16 bg-[#06070a]/50">
    <p>© 2026 Noční knihovna.</p>
  </footer>
</body>
</html>
