---
import { fetchEntries } from '../lib/notion';
import RiddleGenerator from '../components/RiddleGenerator.astro';

const entries = await fetchEntries();

const pohadky = entries.filter(e => e.type === 'Pohádka');
const rikadla = entries.filter(e => e.type === 'Říkadlo');
const pisnicky = entries.filter(e => e.type === 'Písnička');
---

<!DOCTYPE html>
<html lang="cs" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Noční knihovna | Klidný audio svět pro děti a dospělé</title>
  <meta name="description" content="Klidné pohádky na dobrou noc, lidová říkadla a básničky pro děti. Autorské audio a doprovodné perokresby na hnědém papíře.">
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
   .serif { font-family: 'Lora', serif; }
  </style>
</head>
<body class="bg-[#090a10] text-[#e2e8f0] min-h-screen flex flex-col justify-between selection:bg-[#c084fc] selection:text-[#090a10]">

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#1e1b4b]/30 via-[#090a10] to-[#090a10] -z-10"></div>

  <main class="max-w-4xl mx-auto px-4 py-16 w-full space-y-16">
    
    <header class="text-center">
      <div class="relative w-28 h-28 mx-auto mb-6 rounded-full overflow-hidden border-2 border-[#c084fc]/30 shadow-[0_0_20px_rgba(192,132,252,0.15)] bg-[#1e1b4b] flex items-center justify-center text-4xl">
        🌙
      </div>
      <h1 class="serif text-4xl font-semibold tracking-wide text-white mb-2">Noční knihovna</h1>
      <p class="text-[#94a3b8] text-sm max-w-md mx-auto leading-relaxed">
        Klidné pohádky pro usínání dětí, lidová říkadla a bonusové písničky. Doprovázené hřejivou perokresbou.
      </p>
    </header>

    <RiddleGenerator />

    <section>
      <h2 class="serif text-3xl font-medium text-white mb-8 border-b border-[#c084fc]/10 pb-2">📖 Čtené pohádky</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {pohadky.map((p) => (
          <article class="bg-[#131520] border border-[#c084fc]/5 rounded-3xl overflow-hidden transition-all duration-300 hover:border-[#c084fc]/20 flex flex-col justify-between">
            {p.thumbnail && (
              <img src={p.thumbnail} alt={p.title} class="w-full h-48 object-cover opacity-80" />
            )}
            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="serif text-xl font-medium text-white mb-2">{p.title}</h3>
                <p class="text-xs text-[#94a3b8] line-clamp-3 mb-4">{p.content}</p>
              </div>
              <a href={`/pohadky/${p.slug}`} class="text-xs font-semibold text-[#c084fc] hover:text-[#d8b4fe] transition-colors">Číst pohádku a přehrát audio →</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2 class="serif text-3xl font-medium text-white mb-8 border-b border-[#c084fc]/10 pb-2">🌸 Říkadla a básničky</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {rikadla.map((r) => (
          <a href={`/rikadla/${r.slug}`} class="p-5 bg-[#131520] border border-[#c084fc]/5 hover:border-[#c084fc]/30 rounded-2xl transition-all block">
            <span class="text-[10px] font-bold uppercase tracking-wider text-[#c084fc]">{r.category}</span>
            <h3 class="serif text-lg font-medium text-white mt-1">{r.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="serif text-3xl font-medium text-white mb-8 border-b border-[#c084fc]/10 pb-2">🎵 Písničky s doprovodem</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {pisnicky.map((s) => (
          <div class="p-6 bg-[#131520] border border-[#c084fc]/5 rounded-2xl flex justify-between items-center">
            <div>
              <h3 class="serif text-lg font-medium text-white">{s.title}</h3>
              <p class="text-xs text-[#64748b] mt-1">Zpívaný bonus najdete na Herohero</p>
            </div>
            <div class="flex space-x-2">
              <a href={`/pisnicky/${s.slug}`} class="px-3 py-1.5 bg-[#1b1e2e] text-xs font-semibold rounded-lg hover:bg-[#252a3f]">Text</a>
              {s.herohero && (
                <a href={s.herohero} target="_blank" class="px-3 py-1.5 bg-[#c084fc]/20 text-[#e9d5ff] text-xs font-semibold rounded-lg hover:bg-[#c084fc]/30">Poslech ✨</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>

  <footer class="w-full text-center py-8 text-xs text-[#475569] border-t border-[#c084fc]/5 mt-16 bg-[#06070a]/50">
    <p>© 2026 Noční knihovna. Všechna práva vyhrazena.</p>
    <p class="mt-1">Díla v Public Domain upravená s láskou a lidským dotekem.</p>
  </footer>
</body>
</html>
